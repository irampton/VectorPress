<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VectorPress.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="VectorPress.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="VectorPress"
        MinWidth="980"
        MinHeight="680">

    <Window.Styles>
        <Style Selector="Border.preview-shell">
            <Setter Property="Background" Value="#FFF6F0E6" />
            <Setter Property="BorderBrush" Value="#FFE1D5C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Border.sidebar-card">
            <Setter Property="Background" Value="#FFF8F8F6" />
            <Setter Property="BorderBrush" Value="#FFE0DED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#FF1E6B52" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="18,10" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style Selector="TextBox.height-box">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
    </Window.Styles>

    <Grid Background="#FFF0ECE4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid RowDefinitions="Auto,*" Margin="24,24,12,24">
            <Border Classes="preview-shell" Padding="20,18">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Button Classes="primary"
                            Command="{Binding OpenSvgCommand}"
                            Content="Open SVG" />
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedFileName}" />
                        <TextBlock Foreground="#FF5E5A56"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="preview-shell"
                    Margin="0,18,0,0">
                <Grid>
                    <Image Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch" />
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="6"
                                IsVisible="{Binding HasNoPreview}">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Text="SVG preview" />
                        <TextBlock Foreground="#FF5E5A56"
                                   HorizontalAlignment="Center"
                                   Text="Load a file to render it here." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1"
                Classes="sidebar-card"
                Margin="12,24,24,24">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock FontSize="22"
                               FontWeight="Bold"
                               Text="Paint Groups" />
                    <TextBlock Foreground="#FF5E5A56"
                               Text="Assign an extrusion height in millimeters for each grouped paint color. Hover a swatch for the hex value." />
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,18,0,18">
                    <Grid>
                        <ItemsControl ItemsSource="{Binding ColorItems}"
                                      IsVisible="{Binding HasColorItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SidebarColorItemViewModel">
                                    <Border Background="White"
                                            BorderBrush="#FFE4E1DA"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12"
                                            Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="Auto,*,88,Auto" ColumnSpacing="12">
                                            <Border Width="34"
                                                    Height="34"
                                                    CornerRadius="8"
                                                    BorderBrush="#22000000"
                                                    BorderThickness="1"
                                                    Background="{Binding SwatchBrush}"
                                                    ToolTip.Tip="{Binding HexCode}" />
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Label}" />
                                            <TextBox Grid.Column="2"
                                                     Classes="height-box"
                                                     Text="{Binding ExtrusionHeightMm}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Foreground="#FF5E5A56"
                                                       Text="mm" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border IsVisible="{Binding HasNoColorItems}"
                                Background="#33FFFFFF"
                                CornerRadius="14"
                                Padding="16">
                            <TextBlock Foreground="#FF5E5A56"
                                       TextWrapping="Wrap"
                                       Text="No visible paint groups detected yet. Open an SVG to populate extrusion rows." />
                        </Border>
                    </Grid>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Classes="secondary"
                        Height="44"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding CanExport}"
                        Content="Export" />
            </Grid>
        </Border>
    </Grid>

</Window>
